# --- Local & Vercel: use PostgreSQL (Neon, Supabase, etc.) ---
# SQLite is not used anymore (required for Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

SESSION_SECRET="change-this-to-a-long-random-string-at-least-32-chars"

# Must match your deployed portal/API origin (no trailing slash). Same value as iOS API_BASE_URL root.
# NEXT_PUBLIC_SITE_URL="https://sarakbi-patient-app.vercel.app"

# Public marketing website — links from the portal/app open this (not the API host).
# NEXT_PUBLIC_PRACTICE_WEBSITE_URL="https://www.willsarakbi.com"

# Set to false to hide self-service registration (web + mobile app).
# PUBLIC_REGISTRATION=false

# Optional — shown in portal care/messages and in /api/public-config (iOS + web).
# PUBLIC_URGENT_PHONE="+44 ..."
# PUBLIC_URGENT_LABEL="Cadogan urgent advice line"
# PUBLIC_AFTER_HOURS_PHONE=""
# PUBLIC_AFTER_HOURS_LABEL="After-hours"
# PUBLIC_SUPPORT_EMAIL="reception@your-practice.uk"

# Optional: password for prisma seed local users (see prisma/seed.cjs)
# SEED_ACCOUNT_PASSWORD="long-random-string"

# Patient image uploads — Vercel Blob (production). Without this, files are stored locally in .uploads/ (dev only).
# Create a Blob store in Vercel → Storage → Blob → connect to project → BLOB_READ_WRITE_TOKEN is added automatically.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Appointment slots (Europe/London weekdays). Patients may only book these starts; taken slots are excluded.
# APPOINTMENT_SLOT_MINUTES=30
# APPOINTMENT_BOOKING_BUFFER_HOURS=2
# APPOINTMENT_BOOKING_DAYS_AHEAD=56
# APPOINTMENT_DAY_START_HOUR=9
# APPOINTMENT_DAY_END_HOUR=17
