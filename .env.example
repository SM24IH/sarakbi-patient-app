DATABASE_URL="file:./dev.db"
SESSION_SECRET="change-this-to-a-long-random-string-in-production"

# Public site URL (HTTPS, no trailing slash). Used by /api/public-config, marketing links, and should match the iOS API_BASE_URL build setting.
# NEXT_PUBLIC_SITE_URL="https://your-app.netlify.app"

# Set to false to hide self-service registration (web + mobile app).
# PUBLIC_REGISTRATION=false

# Optional — shown in portal care/messages and in /api/public-config (iOS + web).
# Use E.164 or spaces; tel: links strip spaces.
# PUBLIC_URGENT_PHONE="+44 20 0000 0000"
# PUBLIC_URGENT_LABEL="Cadogan urgent advice line"
# PUBLIC_AFTER_HOURS_PHONE=""
# PUBLIC_AFTER_HOURS_LABEL="After-hours"
# PUBLIC_SUPPORT_EMAIL="reception@example.com"
