generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  STAFF
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  phone        String?
  role         Role     @default(PATIENT)
  createdAt    DateTime @default(now())

  appointments Appointment[]
  sentMessages Message[]       @relation("SentMessages")
  threads      MessageThread[] @relation("PatientThreads")
  documents    Document[]     @relation("DocumentPatient")
  authoredDocuments Document[] @relation("DocumentAuthor")
  patientImages PatientImage[]
  invitesCreated PatientInvite[] @relation("InvitesCreated")
  passwordResetTokens PasswordResetToken[]
}

model MessageThread {
  id        String   @id @default(cuid())
  patientId String
  patient   User     @relation("PatientThreads", fields: [patientId], references: [id], onDelete: Cascade)
  subject   String
  /// APPOINTMENT | WOUND_CARE | MEDICATION | RESULTS_OR_LETTERS | ADMIN | OTHER
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
}

model Message {
  id        String        @id @default(cuid())
  threadId  String
  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation("SentMessages", fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime      @default(now())
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  patient     User              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  location    String
  type        String
  requestedAt DateTime
  notes       String?
  status      AppointmentStatus @default(REQUESTED)
  staffNotes  String?
  confirmedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

/// Staff-shared link to a letter, leaflet, or file hosted elsewhere (HTTPS). No binary upload in MVP.
model Document {
  id          String   @id @default(cuid())
  patientId   String
  patient     User     @relation("DocumentPatient", fields: [patientId], references: [id], onDelete: Cascade)
  title       String
  documentUrl String
  notes       String?
  createdById String
  createdBy   User     @relation("DocumentAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

/// Patient-uploaded clinical photos (wound checks, etc.). Files stored in blob/local storage; served via authenticated API.
model PatientImage {
  id              String   @id @default(cuid())
  patientId       String
  patient         User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  filename        String
  mimeType        String
  sizeBytes       Int
  caption         String?
  storageProvider String
  storageKey      String
  createdAt       DateTime @default(now())

  @@index([patientId])
}

/// Staff-issued invite for patient registration (required when public registration is off).
model PatientInvite {
  id          String    @id @default(cuid())
  email       String
  name        String?
  token       String    @unique
  createdById String
  createdBy   User      @relation("InvitesCreated", fields: [createdById], references: [id])
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
